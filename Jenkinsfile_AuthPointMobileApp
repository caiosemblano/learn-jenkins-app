/*
 * AuthPoint Mobile App — Jenkins Pipeline
 *
 * Product   : AuthPoint Mobile (iOS + Android)
 * Team      : Galaxy Guardians
 * Eng Lead  : Talita Goulart
 * PO / PMO  : Fábio Mansur / José Henrique
 * QA        : Caique Santos
 *
 * Platforms : iOS (was-ios-app) | Android
 * OS scope  : iOS 26+  |  Android 16+
 *
 * Parameters
 * ----------
 * PLATFORM        (choice)  : iOS | Android | Both
 * ENVIRONMENT     (choice)  : QA | STAGING | PROD
 * REGION          (choice)  : USA | JPN | DEU
 * SUITE           (choice)  : SMOKE | REGRESSION | FULL
 * BRANCH          (string)  : git branch for the mobile test repository
 * PUBLISH_TESTRAIL(boolean) : push results to TestRail when true
 * MAILTO          (string)  : comma-separated failure notification recipients
 *
 * Agent label: mobile_auto
 *   NOTE: Confirm the actual Jenkins node label with the Galaxy Guardians team.
 *         The Cypress pipeline uses 'api_auto_aws_B'; mobile tests may run on a
 *         macOS or dedicated mobile agent — adjust accordingly.
 */

def AGENT_LABEL = 'mobile_auto'

def runMobileTests(String agentLabel) {
    node(agentLabel) {
        timeout(time: 90, unit: 'MINUTES') {

            stage('Cleanup') {
                sh 'sudo rm -rf *'
            }

            stage('Job creation') {
                script {
                    def displayLabel = params.ENVIRONMENT == 'PROD'
                        ? "#${BUILD_NUMBER} | Env: ${params.ENVIRONMENT} | Reg: ${params.REGION} | Platform: ${params.PLATFORM} | Suite: ${params.SUITE} | Branch: ${params.BRANCH}"
                        : "#${BUILD_NUMBER} | Env: ${params.ENVIRONMENT} | Platform: ${params.PLATFORM} | Suite: ${params.SUITE} | Branch: ${params.BRANCH} | TestRail: ${params.PUBLISH_TESTRAIL}"
                    currentBuild.displayName = displayLabel

                    retry(count: 3) {
                        checkout scm
                    }
                }
            }

            stage('Checkout Tools repo') {
                sh 'mkdir -p Tools'
                dir('Tools') {
                    checkout scmGit(
                        branches: [[name: 'master']],
                        extensions: [[$class: 'CloneOption', shallow: true, noTags: false, reference: '', depth: 1]],
                        userRemoteConfigs: [[credentialsId: 'GitCredentials', url: 'https://github.infra.int.daas-watchguard.com/Team-QA/Tools.git']]
                    )
                }
            }

            stage('Test and Reports') {
                script {
                    try {
                        withCredentials([
                            usernamePassword(credentialsId: 'AUTHPOINT_MOBILE_QA',     usernameVariable: 'MOBILE_QA_USR',     passwordVariable: 'MOBILE_QA_PSW'),
                            usernamePassword(credentialsId: 'AUTHPOINT_MOBILE_QA_JPN', usernameVariable: 'MOBILE_QA_JPN_USR', passwordVariable: 'MOBILE_QA_JPN_PSW'),
                            usernamePassword(credentialsId: 'AUTHPOINT_MOBILE_QA_DEU', usernameVariable: 'MOBILE_QA_DEU_USR', passwordVariable: 'MOBILE_QA_DEU_PSW'),
                            usernamePassword(credentialsId: 'AUTHPOINT_MOBILE_QA_USA', usernameVariable: 'MOBILE_QA_USA_USR', passwordVariable: 'MOBILE_QA_USA_PSW'),
                        ]) {
                            withEnv([
                                "ENVIRONMENT=${params.ENVIRONMENT}",
                                "REGION=${params.REGION}",
                                "SUITE=${params.SUITE}",
                                "BRANCH=${params.BRANCH}",
                                "PLATFORM=${params.PLATFORM}",
                            ]) {
                                if (params.PLATFORM == 'iOS' || params.PLATFORM == 'Both') {
                                    sh '''
                                        echo "--- Running iOS tests (Platform: iOS | Env: ${ENVIRONMENT} | Region: ${REGION} | Suite: ${SUITE} | Branch: ${BRANCH})"
                                        bash ./run_tests.sh \
                                            --platform "iOS" \
                                            --environment "${ENVIRONMENT}" \
                                            --region "${REGION}" \
                                            --suite "${SUITE}" \
                                            --branch "${BRANCH}" \
                                            --username "${MOBILE_QA_USR}" \
                                            --password "${MOBILE_QA_PSW}"
                                    '''
                                }
                                if (params.PLATFORM == 'Android' || params.PLATFORM == 'Both') {
                                    
                                    echo "--- Running Android tests (Platform: Android | Env: ${ENVIRONMENT} | Region: ${REGION} | Suite: ${SUITE} | Branch: ${BRANCH})"
                                    /*
                                    sh '''
                                        echo "--- Running Android tests (Platform: Android | Env: ${ENVIRONMENT} | Region: ${REGION} | Suite: ${SUITE} | Branch: ${BRANCH})"
                                        bash ./run_tests.sh \
                                            --platform "Android" \
                                            --environment "${ENVIRONMENT}" \
                                            --region "${REGION}" \
                                            --suite "${SUITE}" \
                                            --branch "${BRANCH}" \
                                            --username "${MOBILE_QA_USR}" \
                                            --password "${MOBILE_QA_PSW}"
                                    '''
                                    */
                                }
                            }
                        }
                    } finally {
                        try {
                            sh '''
                                if [ -d allure-results ] && [ -n "$(ls -A allure-results 2>/dev/null)" ]; then
                                    npm run mobile:report
                                else
                                    echo "No Allure results found — skipping report generation."
                                fi
                            '''
                            archiveArtifacts artifacts: 'target/*.xml,allure*/*.png', allowEmptyArchive: true
                        } catch (e) {
                            println "Allure artifact archiving failed: ${e}"
                        }
                        try {
                            sh 'sudo chmod -R o+xw allure-results 2>/dev/null || true'
                            sh 'sudo chmod -R o+xw target          2>/dev/null || true'
                            sh 'sudo chmod -R o+xw allure-report   2>/dev/null || true'
                            allure report: 'allure-reports', results: [[path: 'allure*']]
                        } catch (e) {
                            println "Allure publish failed: ${e}"
                        }
                    }
                }
            }

            stage('Publish JUnit Results') {
                junit allowEmptyResults: true, testResults: 'target/*.xml'
            }

            stage('Publish Results to TestRail') {
                script {
                    if ("${params.PUBLISH_TESTRAIL}" == 'true') {
                        withCredentials([string(credentialsId: 'TESTRAIL_API', variable: 'TESTRAIL_API')]) {
                            def python_env = '/usr/bin/python3.11'
                            withPythonEnv(python_env) {
                                sh 'python --version'
                                sh 'pip install trcli'
                                echo 'Generating TestRail result file'
                                sh './Tools/postman_tools/testrail_integration/summarize_junit.sh target/ testrail_results.xml MOBILE'

                                def TEST_SUITE = params.SUITE == 'SMOKE' ? 'SMOKE_TEST' : 'REGRESSION_TEST'

                                echo "Identify Test Suite: testrail_mapping.py TESTSUITE MOBILE ${TEST_SUITE} ${params.ENVIRONMENT} ${params.REGION}"
                                def TESTRAIL_TESTSUITE = sh(
                                    script: "python3 Tools/postman_tools/testrail_integration/testrail_mapping.py TESTSUITE MOBILE ${TEST_SUITE} ${params.ENVIRONMENT} ${params.REGION}",
                                    returnStdout: true
                                ).trim()

                                echo "Identify Test Run: testrail_mapping.py TESTRUN MOBILE ${TEST_SUITE} ${params.ENVIRONMENT} ${params.REGION}"
                                def TESTRAIL_TESTRUN = sh(
                                    script: "python3 Tools/postman_tools/testrail_integration/testrail_mapping.py TESTRUN MOBILE ${TEST_SUITE} ${params.ENVIRONMENT} ${params.REGION}",
                                    returnStdout: true
                                ).trim()

                                echo "Identify Milestone: testrail_mapping.py MILESTONE MOBILE ${TEST_SUITE} ${params.ENVIRONMENT} ${params.REGION}"
                                def TESTRAIL_MILESTONE = sh(
                                    script: "python3 Tools/postman_tools/testrail_integration/testrail_mapping.py MILESTONE MOBILE ${TEST_SUITE} ${params.ENVIRONMENT} ${params.REGION}",
                                    returnStdout: true
                                ).trim()

                                echo "Uploading to TestRail (suite: ${TESTRAIL_TESTSUITE}, run: ${TESTRAIL_TESTRUN})"
                                withEnv([
                                    "TESTRAIL_TESTSUITE=${TESTRAIL_TESTSUITE}",
                                    "TESTRAIL_TESTRUN=${TESTRAIL_TESTRUN}",
                                    "TEST_SUITE=${TEST_SUITE}",
                                    "TEST_ENV=${params.ENVIRONMENT}",
                                    "TEST_REGION=${params.REGION}",
                                    "TESTRAIL_MILESTONE=${TESTRAIL_MILESTONE}",
                                ]) {
                                    sh '''
                                        trcli -y \
                                            -h https://watchguardqa.testrail.io \
                                            --project "WGC Automation" \
                                            --username wats-ng-dev@watchguard.com \
                                            -k ${TESTRAIL_API} \
                                            parse_junit \
                                            --title "Mobile - ${TEST_SUITE} - ${TEST_ENV} - ${TEST_REGION}" \
                                            -f testrail_results.xml \
                                            --suite-id "${TESTRAIL_TESTSUITE}" \
                                            --run-id "${TESTRAIL_TESTRUN}" \
                                            --milestone-id "${TESTRAIL_MILESTONE}"
                                    '''
                                }
                            }
                        }
                    }
                }
            }

            stage('Publish Email Report') {
                sh 'sudo chmod -R o+w target || true'
                sh """
                    python3 custom_job/generate_email_template.py \\
                        --junit-dir target \\
                        --output target/email_report.html \\
                        --current-summary target/results_summary.json \\
                        --feature "Mobile ${params.PLATFORM} ${params.SUITE}-${params.ENVIRONMENT}" \\
                        --job-name ${env.JOB_NAME} \\
                        --build-number ${env.BUILD_NUMBER} \\
                        --build-url ${env.BUILD_URL}
                """
                archiveArtifacts artifacts: 'target/results_summary.json,target/email_report.html', fingerprint: true
                publishHTML([
                    allowMissing: false,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: 'target',
                    reportFiles: 'email_report.html',
                    reportName: 'Mobile Test Summary Report'
                ])
                script {
                    if (currentBuild.result == 'FAILURE' && params.MAILTO?.trim()) {
                        emailext(
                            subject: "[FAILURE] ${env.JOB_NAME} #${env.BUILD_NUMBER} — ${params.PLATFORM} | ${params.ENVIRONMENT} | ${params.SUITE}",
                            body: """
                                <p>The AuthPoint Mobile automated test run has failed.</p>
                                <ul>
                                    <li><b>Platform:</b> ${params.PLATFORM}</li>
                                    <li><b>Environment:</b> ${params.ENVIRONMENT}</li>
                                    <li><b>Region:</b> ${params.REGION}</li>
                                    <li><b>Suite:</b> ${params.SUITE}</li>
                                    <li><b>Branch:</b> ${params.BRANCH}</li>
                                    <li><b>Build URL:</b> <a href="${env.BUILD_URL}">${env.BUILD_URL}</a></li>
                                </ul>
                            """,
                            mimeType: 'text/html',
                            to: params.MAILTO
                        )
                    }
                }
            }

        } // end timeout
    } // end node
}

// ── Pipeline entry point ─────────────────────────────────────────────────────

properties([
    parameters([
        choice(
            name: 'PLATFORM',
            choices: ['iOS', 'Android', 'Both'],
            description: 'Target mobile platform(s). "Both" runs iOS first, then Android sequentially on the same agent.'
        ),
        choice(
            name: 'ENVIRONMENT',
            choices: ['QA', 'STAGING', 'PROD'],
            description: 'Target runtime environment. PROD requires REGION to be set explicitly.'
        ),
        choice(
            name: 'REGION',
            choices: ['USA', 'JPN', 'DEU'],
            description: 'Geographic region for the target stack. Relevant for PROD and multi-region QA runs.'
        ),
        choice(
            name: 'SUITE',
            choices: ['SMOKE', 'REGRESSION', 'FULL'],
            description: 'Test suite scope. SMOKE = quick sanity; REGRESSION = full functional coverage; FULL = regression + OS compatibility + UX.'
        ),
        string(
            name: 'BRANCH',
            defaultValue: 'master',
            description: 'Git branch of the mobile test repository to check out.'
        ),
        booleanParam(
            name: 'PUBLISH_TESTRAIL',
            defaultValue: false,
            description: 'When true, upload JUnit results to TestRail after execution.'
        ),
        string(
            name: 'MAILTO',
            defaultValue: '',
            description: 'Comma-separated list of email recipients for failure notifications. Leave empty to skip email.'
        ),
    ])
])

runMobileTests(AGENT_LABEL)
