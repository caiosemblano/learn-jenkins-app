/*
 * AuthPoint Logon App — Jenkins Pipeline (macOS)
 *
 * Product   : AuthPoint Logon App for macOS
 * Team      : (confirm with team)
 *
 * OS scope  : El Capitan (10.11) through Tahoe (26.x), including:
 *               Big Sur (11.x), Monterey (12.x), Ventura (13.x),
 *               Sonoma (14.x), Sequoia (15.x), Tahoe (26.x)
 * App version: 2.1.0 (as of April 2026)
 * Source    : https://www.watchguard.com/support/release-notes/Cloud/Content/en-US/AuthPoint/OS-compatibility_authpoint.html
 *
 * Parameters
 * ----------
 * OS_VERSION       (choice)  : Sequoia (15.x) | Sonoma (14.x) | Ventura (13.x) | ...
 * ENVIRONMENT      (choice)  : QA | STAGING | PROD
 * REGION           (choice)  : USA | JPN | DEU
 * SUITE            (choice)  : SMOKE | REGRESSION
 * BRANCH           (string)  : git branch for the Logon App test repository
 * PUBLISH_TESTRAIL (boolean) : push results to TestRail when true
 * MAILTO           (string)  : comma-separated failure notification recipients
 *
 * Agent label: macos_logon_auto
 *   NOTE: Confirm the actual Jenkins node label with the team.
 *         The agent must be a macOS machine with the test framework installed.
 *         If tests target multiple macOS versions via VMs or containers, adjust accordingly.
 */

def AGENT_LABEL = 'macos_logon_auto'

def runLogonTests(String agentLabel) {
    node(agentLabel) {
        timeout(time: 60, unit: 'MINUTES') {

            stage('Cleanup') {
                sh 'sudo rm -rf *'
            }

            stage('Job creation') {
                script {
                    def displayLabel = params.ENVIRONMENT == 'PROD'
                        ? "#${BUILD_NUMBER} | Env: ${params.ENVIRONMENT} | Reg: ${params.REGION} | OS: ${params.OS_VERSION} | Suite: ${params.SUITE} | Branch: ${params.BRANCH}"
                        : "#${BUILD_NUMBER} | Env: ${params.ENVIRONMENT} | OS: ${params.OS_VERSION} | Suite: ${params.SUITE} | Branch: ${params.BRANCH} | TestRail: ${params.PUBLISH_TESTRAIL}"
                    currentBuild.displayName = displayLabel

                    retry(count: 3) {
                        checkout scm
                    }
                }
            }

            stage('Checkout Tools repo') {
                sh 'mkdir -p Tools'
                dir('Tools') {
                    checkout scmGit(
                        branches: [[name: 'master']],
                        extensions: [[$class: 'CloneOption', shallow: true, noTags: false, reference: '', depth: 1]],
                        userRemoteConfigs: [[credentialsId: 'GitCredentials', url: 'https://github.infra.int.daas-watchguard.com/Team-QA/Tools.git']]
                    )
                }
            }

            stage('Test and Reports') {
                script {
                    try {
                        withCredentials([
                            usernamePassword(credentialsId: 'AUTHPOINT_LOGON_QA',     usernameVariable: 'LOGON_QA_USR',     passwordVariable: 'LOGON_QA_PSW'),
                            usernamePassword(credentialsId: 'AUTHPOINT_LOGON_QA_JPN', usernameVariable: 'LOGON_QA_JPN_USR', passwordVariable: 'LOGON_QA_JPN_PSW'),
                            usernamePassword(credentialsId: 'AUTHPOINT_LOGON_QA_DEU', usernameVariable: 'LOGON_QA_DEU_USR', passwordVariable: 'LOGON_QA_DEU_PSW'),
                            usernamePassword(credentialsId: 'AUTHPOINT_LOGON_QA_USA', usernameVariable: 'LOGON_QA_USA_USR', passwordVariable: 'LOGON_QA_USA_PSW'),
                        ]) {
                            withEnv([
                                "ENVIRONMENT=${params.ENVIRONMENT}",
                                "REGION=${params.REGION}",
                                "SUITE=${params.SUITE}",
                                "BRANCH=${params.BRANCH}",
                                "OS_VERSION=${params.OS_VERSION}",
                            ]) {
                                sh '''
                                    echo "--- Running macOS Logon App tests (OS: ${OS_VERSION} | Env: ${ENVIRONMENT} | Region: ${REGION} | Suite: ${SUITE} | Branch: ${BRANCH})"
                                    bash ./run_tests.sh \
                                        --os-version "${OS_VERSION}" \
                                        --environment "${ENVIRONMENT}" \
                                        --region "${REGION}" \
                                        --suite "${SUITE}" \
                                        --branch "${BRANCH}" \
                                        --username "${LOGON_QA_USR}" \
                                        --password "${LOGON_QA_PSW}"
                                '''
                            }
                        }
                    } finally {
                        try {
                            sh '''
                                if [ -d allure-results ] && [ -n "$(ls -A allure-results 2>/dev/null)" ]; then
                                    npm run logon:report
                                else
                                    echo "No Allure results found — skipping report generation."
                                fi
                            '''
                            archiveArtifacts artifacts: 'target/*.xml,allure*/*.png', allowEmptyArchive: true
                        } catch (e) {
                            println "Allure artifact archiving failed: ${e}"
                        }
                        try {
                            sh 'sudo chmod -R o+xw allure-results 2>/dev/null || true'
                            sh 'sudo chmod -R o+xw target          2>/dev/null || true'
                            sh 'sudo chmod -R o+xw allure-report   2>/dev/null || true'
                            allure report: 'allure-reports', results: [[path: 'allure*']]
                        } catch (e) {
                            println "Allure publish failed: ${e}"
                        }
                    }
                }
            }

            stage('Publish JUnit Results') {
                junit allowEmptyResults: true, testResults: 'target/*.xml'
            }

            stage('Publish Results to TestRail') {
                script {
                    if ("${params.PUBLISH_TESTRAIL}" == 'true') {
                        withCredentials([string(credentialsId: 'TESTRAIL_API', variable: 'TESTRAIL_API')]) {
                            def python_env = '/usr/bin/python3.11'
                            withPythonEnv(python_env) {
                                sh 'python --version'
                                sh 'pip install trcli'
                                echo 'Generating TestRail result file'
                                sh './Tools/postman_tools/testrail_integration/summarize_junit.sh target/ testrail_results.xml LOGON_MAC'

                                def TEST_SUITE = params.SUITE == 'SMOKE' ? 'SMOKE_TEST' : 'REGRESSION_TEST'

                                echo "Identify Test Suite: testrail_mapping.py TESTSUITE LOGON_MAC ${TEST_SUITE} ${params.ENVIRONMENT} ${params.REGION}"
                                def TESTRAIL_TESTSUITE = sh(
                                    script: "python3 Tools/postman_tools/testrail_integration/testrail_mapping.py TESTSUITE LOGON_MAC ${TEST_SUITE} ${params.ENVIRONMENT} ${params.REGION}",
                                    returnStdout: true
                                ).trim()

                                echo "Identify Test Run: testrail_mapping.py TESTRUN LOGON_MAC ${TEST_SUITE} ${params.ENVIRONMENT} ${params.REGION}"
                                def TESTRAIL_TESTRUN = sh(
                                    script: "python3 Tools/postman_tools/testrail_integration/testrail_mapping.py TESTRUN LOGON_MAC ${TEST_SUITE} ${params.ENVIRONMENT} ${params.REGION}",
                                    returnStdout: true
                                ).trim()

                                echo "Identify Milestone: testrail_mapping.py MILESTONE LOGON_MAC ${TEST_SUITE} ${params.ENVIRONMENT} ${params.REGION}"
                                def TESTRAIL_MILESTONE = sh(
                                    script: "python3 Tools/postman_tools/testrail_integration/testrail_mapping.py MILESTONE LOGON_MAC ${TEST_SUITE} ${params.ENVIRONMENT} ${params.REGION}",
                                    returnStdout: true
                                ).trim()

                                echo "Uploading to TestRail (suite: ${TESTRAIL_TESTSUITE}, run: ${TESTRAIL_TESTRUN})"
                                withEnv([
                                    "TESTRAIL_TESTSUITE=${TESTRAIL_TESTSUITE}",
                                    "TESTRAIL_TESTRUN=${TESTRAIL_TESTRUN}",
                                    "TEST_SUITE=${TEST_SUITE}",
                                    "TEST_ENV=${params.ENVIRONMENT}",
                                    "TEST_REGION=${params.REGION}",
                                    "TESTRAIL_MILESTONE=${TESTRAIL_MILESTONE}",
                                ]) {
                                    sh '''
                                        trcli -y \
                                            -h https://watchguardqa.testrail.io \
                                            --project "WGC Automation" \
                                            --username wats-ng-dev@watchguard.com \
                                            -k ${TESTRAIL_API} \
                                            parse_junit \
                                            --title "Logon macOS - ${TEST_SUITE} - ${TEST_ENV} - ${TEST_REGION}" \
                                            -f testrail_results.xml \
                                            --suite-id "${TESTRAIL_TESTSUITE}" \
                                            --run-id "${TESTRAIL_TESTRUN}" \
                                            --milestone-id "${TESTRAIL_MILESTONE}"
                                    '''
                                }
                            }
                        }
                    }
                }
            }

            stage('Publish Email Report') {
                sh 'sudo chmod -R o+w target || true'
                sh """
                    python3 custom_job/generate_email_template.py \\
                        --junit-dir target \\
                        --output target/email_report.html \\
                        --current-summary target/results_summary.json \\
                        --feature "Logon macOS ${params.OS_VERSION} ${params.SUITE}-${params.ENVIRONMENT}" \\
                        --job-name ${env.JOB_NAME} \\
                        --build-number ${env.BUILD_NUMBER} \\
                        --build-url ${env.BUILD_URL}
                """
                archiveArtifacts artifacts: 'target/results_summary.json,target/email_report.html', fingerprint: true
                publishHTML([
                    allowMissing: false,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: 'target',
                    reportFiles: 'email_report.html',
                    reportName: 'Logon macOS Test Summary Report'
                ])
                script {
                    if (currentBuild.result == 'FAILURE' && params.MAILTO?.trim()) {
                        emailext(
                            subject: "[FAILURE] ${env.JOB_NAME} #${env.BUILD_NUMBER} — ${params.OS_VERSION} | ${params.ENVIRONMENT} | ${params.SUITE}",
                            body: """
                                <p>The AuthPoint Logon App (macOS) automated test run has failed.</p>
                                <ul>
                                    <li><b>OS Version:</b> ${params.OS_VERSION}</li>
                                    <li><b>Environment:</b> ${params.ENVIRONMENT}</li>
                                    <li><b>Region:</b> ${params.REGION}</li>
                                    <li><b>Suite:</b> ${params.SUITE}</li>
                                    <li><b>Branch:</b> ${params.BRANCH}</li>
                                    <li><b>Build URL:</b> <a href="${env.BUILD_URL}">${env.BUILD_URL}</a></li>
                                </ul>
                            """,
                            mimeType: 'text/html',
                            to: params.MAILTO
                        )
                    }
                }
            }

        } // end timeout
    } // end node
}

// ── Pipeline entry point ─────────────────────────────────────────────────────

properties([
    parameters([
        choice(
            name: 'OS_VERSION',
            choices: [
                'Sequoia (15.x)',
                'Sonoma (14.x)',
                'Ventura (13.x)',
                'Monterey (12.x)',
                'Big Sur (11.x)',
            ],
            description: 'Target macOS version under test. All versions from El Capitan (10.11) through Tahoe (26.x) are supported. See: https://www.watchguard.com/support/release-notes/Cloud/Content/en-US/AuthPoint/OS-compatibility_authpoint.html'
        ),
        choice(
            name: 'ENVIRONMENT',
            choices: ['QA', 'STAGING', 'PROD'],
            description: 'Target runtime environment. PROD requires REGION to be set explicitly.'
        ),
        choice(
            name: 'REGION',
            choices: ['USA', 'JPN', 'DEU'],
            description: 'Geographic region for the target stack. Relevant for PROD and multi-region QA runs.'
        ),
        choice(
            name: 'SUITE',
            choices: ['SMOKE', 'REGRESSION'],
            description: 'Test suite scope. SMOKE = quick sanity; REGRESSION = full functional coverage.'
        ),
        string(
            name: 'BRANCH',
            defaultValue: 'master',
            description: 'Git branch of the Logon App test repository to check out.'
        ),
        booleanParam(
            name: 'PUBLISH_TESTRAIL',
            defaultValue: false,
            description: 'When true, upload JUnit results to TestRail after execution. Requires LOGON_MAC product type in testrail_mapping.py.'
        ),
        string(
            name: 'MAILTO',
            defaultValue: '',
            description: 'Comma-separated list of email recipients for failure notifications. Leave empty to skip email.'
        ),
    ])
])

runLogonTests(AGENT_LABEL)
